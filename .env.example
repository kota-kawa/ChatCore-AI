# Email Service
SEND_ADDRESS=your_email@example.com
SEND_PASSWORD=your_app_password_here

# Admin
# Generate with:
# python3 -c "from services.security import hash_password; print(hash_password('your_admin_password_here'))"
# When using Docker Compose `.env`, escape `$` as `$$` in hash values.
ADMIN_PASSWORD_HASH='pbkdf2_sha256$iterations$salt$hash'

# Database
POSTGRES_USER=chatuser
POSTGRES_PASSWORD=chatpass
POSTGRES_DB=chat_db
DB_POOL_MIN_CONN=1
DB_POOL_MAX_CONN=10
# プール枯渇時に接続確保を待つ上限秒数。超えると 503 + Retry-After を返す。
# Bounded wait (seconds) for acquiring a pooled connection; exceeding it yields 503 + Retry-After.
DB_POOL_ACQUIRE_TIMEOUT_SECONDS=10
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=generate_a_strong_redis_password_here

# Scaling / Concurrency
# uvicorn のワーカープロセス数。CPUコアを使い切るために増やす。
# WEB_CONCURRENCY * DB_POOL_MAX_CONN < POSTGRES_MAX_CONNECTIONS を必ず満たすこと
# （Blue/Green では blue+green が同時稼働しうるので 2 * WEB_CONCURRENCY * DB_POOL_MAX_CONN で見積もる）。
# Number of uvicorn worker processes; raise to use all CPU cores.
# Keep WEB_CONCURRENCY * DB_POOL_MAX_CONN < POSTGRES_MAX_CONNECTIONS
# (size for 2 * WEB_CONCURRENCY * DB_POOL_MAX_CONN under Blue/Green, where both colors overlap).
WEB_CONCURRENCY=2
# 1ワーカーあたりのブロッキングI/O（同期DB・外部HTTP等）の同時実行上限。
# Per-worker concurrency budget for blocking I/O (sync DB, outbound HTTP, etc.).
RUN_BLOCKING_MAX_WORKERS=64
# 共有HTTPセッションのコネクションプールサイズ（外部API呼び出し用）。
# Connection pool size for the shared outbound HTTP session.
HTTP_POOL_MAXSIZE=32

# Postgres tuning (passed to the postgres container as -c flags)
POSTGRES_MAX_CONNECTIONS=150
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1536MB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
# この時間(ms)を超えるクエリをスロークエリとしてログ出力する。
# Log queries slower than this many milliseconds as slow queries.
POSTGRES_LOG_MIN_DURATION_MS=500

# Redis のメモリ上限。maxmemory-policy は volatile-lru 固定（TTL付きキーのみ退避）。
# Redis memory ceiling; the policy is fixed to volatile-lru (only keys with a TTL are evicted).
REDIS_MAXMEMORY=4gb

# Security
FASTAPI_SECRET_KEY=generate_a_strong_secret_key_here
FASTAPI_ENV=production
# Lax keeps OAuth top-level redirects working while avoiding iframe/subresource session sends.
FASTAPI_SESSION_SAMESITE=lax

# Passkey / WebAuthn
# RP ID: サイトのドメイン名（例: chatcore-ai.com）。未設定時は FRONTEND_URL のホスト名を使用。
# プロキシ構成の場合は必ず明示的に設定すること。
WEBAUTHN_RP_ID=chatcore-ai.com
# 許可オリジン: カンマ区切りで複数指定可能。未設定時は FRONTEND_URL から自動生成。
# PASSKEY_ORIGINS=https://chatcore-ai.com

# API Keys
GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_JS_ORIGIN=https://chatcore-ai.com
GOOGLE_REDIRECT_URI=https://chatcore-ai.com/google-callback
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=4096

# groq API Keys
GROQ_API_KEY=
BRAVE_API_KEY=
BRAVE_WEB_SEARCH_MONTHLY_LIMIT=500
GROQ_MODEL=openai/gpt-oss-20b

# Daily LLM API limit (all users combined)
LLM_DAILY_API_LIMIT=300

# Monthly support AI agent API limit (all users combined)
AI_AGENT_MONTHLY_API_LIMIT=1000

# Daily auth email send limit (all users combined)
AUTH_EMAIL_DAILY_SEND_LIMIT=50

# Daily guest chat limit (per client IP)
GUEST_CHAT_DAILY_LIMIT=10

# Comma-separated proxy IPs/CIDRs allowed to supply X-Forwarded-For / X-Real-IP
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Logging / Observability
LOG_LEVEL=INFO
LOG_OUTPUT=json

# SEO
# 本番サイトのURL（末尾スラッシュなし）。canonical URL・sitemap・OG URLに使用。
NEXT_PUBLIC_SITE_URL=https://chatcore-ai.com
# X(Twitter)の公式アカウントがあれば設定（例: @chatcoreai）。未設定でも動作する。
NEXT_PUBLIC_TWITTER_SITE=
